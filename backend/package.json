{
  "name": "betet-platform-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant betting platform backend (Express + Postgres + RLS).",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "keys:generate": "node scripts/generate-jwt-keys.js",
    "migrate": "node-pg-migrate up -m \"/migrations/*.js\" --use-glob",
    "migrate:rollback": "node-pg-migrate down -m \"/migrations/*.js\" --use-glob",
    "migrate:latest": "node-pg-migrate up -m \"/migrations/*.js\" --use-glob",
    "migrate:down": "node-pg-migrate down -m \"/migrations/*.js\" --use-glob",
    "seed": "tsx src/scripts/seed.ts",
    "setup": "npm run migrate && npm run seed",
    "reset-db": "node-pg-migrate down -m \"/migrations/*.js\" --use-glob -j && npm run migrate && npm run seed"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "ipaddr.js": "^2.4.0",
    "jsonwebtoken": "^9.0.2",
    "node-cache": "^5.1.2",
    "pg": "^8.11.5",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "node-pg-migrate": "^8.0.3",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
