# --- Runtime ---
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# --- Database ---
# IMPORTANT: this user must NOT have BYPASSRLS. RLS is required for tenant
# isolation. Use a separate, privileged role only for migrations.
DATABASE_URL=postgres://betet:betet@localhost:5432/betet

# --- JWT (RS256) ---
# Either point at PEM files generated by `npm run keys:generate`,
# or paste base64-encoded PEM into the *_KEY vars (handy for cloud secrets).
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=

JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d
JWT_ISSUER=betet-platform
JWT_AUDIENCE=betet-platform

# --- Passwords / lockout ---
# Spec defaults (per security_settings table): 5 failed attempts trigger a
# 15-minute lockout; password-reset link valid for 60 minutes.
BCRYPT_COST=12
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=15
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# --- Rate limiting ---
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15

# --- Tenant resolution ---
# Header used to carry tenant context (UUID or tenant slug).
TENANT_HEADER=x-tenant-id
# Optional: base domain for subdomain-based tenant routing.
# Example: 'betops.et' so client.betops.et resolves to tenant slug=client.
# TENANT_DOMAIN_BASE=betops.et

# --- CORS ---
# Comma-separated list of always-allowed origins (admin / dev / cdn).
# Per-tenant origins are additionally read from tenants.config->'cors_origins'.
# Include 5174 when Vite picks the next free port; 127.0.0.1 ≠ localhost for CORS.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3003,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3003,http://127.0.0.1:5173

# --- Payment gateways / providers ---
TELEBIRR_API_KEY=
TELEBIRR_BASE_URL=https://api.telebirr.com
CHAPA_API_KEY=
CHAPA_BASE_URL=https://api.chapa.co
CHAPA_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=

# --- Odds / data providers ---
BETRADAR_API_KEY=
BETRADAR_BASE_URL=https://api.betradar.com
SPORTRADAR_API_KEY=

# --- Game providers ---
PRAGMATIC_PLAY_KEY=
SPRIBE_KEY=
